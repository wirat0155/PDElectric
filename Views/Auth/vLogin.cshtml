@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - EmissiView</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="~/lib/remixicon/fonts/remixicon.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/Page/vLogin.css" rel="stylesheet" asp-append-version="true">
</head>
<body class="min-h-screen flex items-center justify-center px-4 py-8">
    <div class="loader" id="loader"></div>

    <div class="w-full max-w-md">
        <!-- Logo & Title Card -->
        <div class="bg-white rounded-2xl shadow-lg border border-slate-200 p-8 mb-6 text-center">
            <div class="flex justify-center items-center gap-4 mb-4">
                <img src="~/images/usui-logo-rev.svg" alt="Usui Logo" class="h-10 w-auto">
                <div class="w-px h-8 bg-slate-200"></div>
                <img src="~/images/electric_logo.png" alt="Electric Logo" class="h-10 w-auto rounded-lg">
            </div>
            <h1 class="text-2xl font-bold text-slate-800 mb-1">EmissiView</h1>
            <p class="text-sm text-slate-500">Powering Sustainable Production</p>
        </div>

        <!-- Login Form Card -->
        <div class="bg-white rounded-2xl shadow-lg border border-slate-200 p-8">
            <div class="text-center mb-6">
                <h2 class="text-xl font-semibold text-slate-800">Welcome Back</h2>
                <p class="text-sm text-slate-500 mt-1">Sign in to access the admin portal</p>
            </div>

            <form id="loginForm" class="space-y-5">
                <div>
                    <label for="txt_empno" class="block text-sm font-medium text-slate-700 mb-1.5">Employee ID</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="ri-user-line text-slate-400 text-lg"></i>
                        </div>
                        <input type="text" name="txt_empno" id="txt_empno"
                            class="block w-full pl-10 pr-4 py-2.5 border border-slate-300 rounded-lg text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#00aef0] focus:border-[#00aef0] transition-colors"
                            placeholder="Enter your employee ID">
                    </div>
                    <p class="error text-red-500 text-sm mt-1" id="txt_empno"></p>
                </div>

                <div>
                    <label for="txt_password" class="block text-sm font-medium text-slate-700 mb-1.5">Password</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="ri-lock-line text-slate-400 text-lg"></i>
                        </div>
                        <input type="password" name="txt_password" id="txt_password"
                            class="block w-full pl-10 pr-4 py-2.5 border border-slate-300 rounded-lg text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#00aef0] focus:border-[#00aef0] transition-colors"
                            placeholder="Enter your password">
                    </div>
                    <p class="error text-red-500 text-sm mt-1" id="txt_password"></p>
                </div>

                <button type="submit" name="btn_login" value="1"
                    class="w-full flex justify-center items-center gap-2 py-2.5 px-4 border border-transparent rounded-lg text-sm font-medium text-white bg-[#00aef0] hover:bg-[#0090c7] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#00aef0] transition-colors shadow-sm">
                    <i class="ri-login-box-line"></i>
                    Sign In
                </button>
            </form>
        </div>

        <!-- Footer -->
        <div class="text-center mt-6 flex items-center justify-center gap-3 text-slate-500 text-sm">
            <a href="@Url.Action("Index", "ElectricChart")" class="flex items-center gap-1.5 hover:text-slate-700 transition-colors">
                <i class="ri-home-4-line"></i>
                <span>Back to Dashboard</span>
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/page/Auth/vLogin.js" asp-append-version="true"></script>
</body>
</html>